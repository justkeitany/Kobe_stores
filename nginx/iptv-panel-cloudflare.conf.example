# ================================================================
#  IPTV Panel — Nginx + Cloudflare configuration
#  Domain: tv.keitanyfrank.store
#  Port 80/443 → Admin dashboard (Cloudflare proxied)
#  Port 8080   → Xtream Codes API (direct, no proxy)
# ================================================================

# ── Cloudflare IP ranges ──────────────────────────────────────
# Source: https://www.cloudflare.com/ips/
geo $cloudflare_ip {
    default          0;
    103.21.244.0/22  1;
    103.22.200.0/22  1;
    103.31.4.0/22    1;
    104.16.0.0/13    1;
    104.24.0.0/14    1;
    108.162.192.0/18 1;
    131.0.72.0/22    1;
    141.101.64.0/18  1;
    162.158.0.0/15   1;
    172.64.0.0/13    1;
    173.245.48.0/20  1;
    188.114.96.0/20  1;
    190.93.240.0/20  1;
    197.234.240.0/22 1;
    198.41.128.0/17  1;
    # IPv6 Cloudflare ranges
    2400:cb00::/32   1;
    2606:4700::/32   1;
    2803:f800::/32   1;
    2405:b500::/32   1;
    2405:8100::/32   1;
    2a06:98c0::/29   1;
    2c0f:f248::/32   1;
}

limit_req_zone  $binary_remote_addr zone=api:10m    rate=30r/s;
limit_req_zone  $binary_remote_addr zone=stream:10m rate=20r/s;
limit_conn_zone $binary_remote_addr zone=stream_conn:10m;

upstream iptv_backend {
    server 127.0.0.1:8000;
    keepalive 64;
}

# ── Block direct VPS IP access on port 80 ────────────────────
# Returns 444 for any request that doesn't match tv.keitanyfrank.store
# This blocks direct IP access while allowing Cloudflare through
server {
    listen 80 default_server;
    listen [::]:80 default_server;
    server_name _;
    return 444;
}

# ── Port 80 — Admin Dashboard (Cloudflare proxied) ────────────
server {
    listen 80;
    listen [::]:80;
    server_name tv.keitanyfrank.store;

    # Real visitor IP from Cloudflare header
    real_ip_header    CF-Connecting-IP;
    set_real_ip_from  103.21.244.0/22;
    set_real_ip_from  103.22.200.0/22;
    set_real_ip_from  103.31.4.0/22;
    set_real_ip_from  104.16.0.0/13;
    set_real_ip_from  104.24.0.0/14;
    set_real_ip_from  108.162.192.0/18;
    set_real_ip_from  131.0.72.0/22;
    set_real_ip_from  141.101.64.0/18;
    set_real_ip_from  162.158.0.0/15;
    set_real_ip_from  172.64.0.0/13;
    set_real_ip_from  173.245.48.0/20;
    set_real_ip_from  188.114.96.0/20;
    set_real_ip_from  190.93.240.0/20;
    set_real_ip_from  197.234.240.0/22;
    set_real_ip_from  198.41.128.0/17;

    access_log /var/log/nginx/iptv-access.log combined buffer=16k flush=5s;
    error_log  /var/log/nginx/iptv-error.log warn;

    # Security headers
    add_header X-Frame-Options       "SAMEORIGIN"            always;
    add_header X-Content-Type-Options "nosniff"              always;
    add_header X-XSS-Protection       "1; mode=block"        always;
    add_header Referrer-Policy        "no-referrer"          always;

    # WebSocket — live stats
    location /ws/ {
        proxy_pass http://iptv_backend;
        proxy_http_version 1.1;
        proxy_set_header Upgrade    $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host       $host;
        proxy_set_header X-Real-IP  $remote_addr;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }

    # REST API
    location /api/ {
        limit_req zone=api burst=50 nodelay;
        proxy_pass http://iptv_backend;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host            $host;
        proxy_set_header X-Real-IP       $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        client_max_body_size 200M;
        proxy_connect_timeout 30s;
        proxy_send_timeout    120s;
        proxy_read_timeout    120s;
    }

    # ── Xtream Codes API (served on same domain port 80) ──────
    # Players connect to http://tv.keitanyfrank.store (port 80)
    location ~ ^/(player_api\.php|get\.php|xmltv\.php|panel_api\.php) {
        limit_req zone=api burst=30 nodelay;
        proxy_pass http://iptv_backend;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host      $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_connect_timeout 10s;
        proxy_send_timeout    30s;
        proxy_read_timeout    30s;
        proxy_buffering off;
        add_header Access-Control-Allow-Origin * always;
    }

    # HLS segments
    location /hls/ {
        alias /var/iptv/hls/;
        types {
            application/vnd.apple.mpegurl m3u8;
            video/mp2t                    ts;
        }
        location ~* \.m3u8$ {
            add_header Cache-Control "no-cache, no-store, must-revalidate" always;
            add_header Access-Control-Allow-Origin * always;
        }
        location ~* \.ts$ {
            add_header Cache-Control "public, max-age=10" always;
            add_header Access-Control-Allow-Origin * always;
        }
        limit_conn stream_conn 10;
    }

    # Live stream delivery
    location /live/ {
        limit_req  zone=stream burst=20 nodelay;
        limit_conn stream_conn 5;
        proxy_pass http://iptv_backend;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host      $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_connect_timeout 15s;
        proxy_send_timeout    120s;
        proxy_read_timeout    120s;
        proxy_buffering off;
        add_header Access-Control-Allow-Origin * always;
    }

    # Frontend SPA
    location / {
        root /var/www/iptv-panel;
        index index.html;
        try_files $uri $uri/ /index.html;
        location ~* \.(js|css|svg|woff|woff2|ico)$ {
            expires 30d;
            add_header Cache-Control "public, immutable";
        }
    }

    gzip on;
    gzip_vary on;
    gzip_min_length 1024;
    gzip_types text/plain application/json application/javascript text/css;
}

# ── Port 443 — Admin Dashboard HTTPS (Cloudflare proxied) ────
server {
    listen 443 ssl;
    listen [::]:443 ssl;
    server_name tv.keitanyfrank.store;

    ssl_certificate     /etc/letsencrypt/live/tv.keitanyfrank.store/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/tv.keitanyfrank.store/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_session_cache   shared:SSL:10m;
    ssl_prefer_server_ciphers off;

    real_ip_header CF-Connecting-IP;
    set_real_ip_from  103.21.244.0/22;
    set_real_ip_from  103.22.200.0/22;
    set_real_ip_from  103.31.4.0/22;
    set_real_ip_from  104.16.0.0/13;
    set_real_ip_from  104.24.0.0/14;
    set_real_ip_from  108.162.192.0/18;
    set_real_ip_from  131.0.72.0/22;
    set_real_ip_from  141.101.64.0/18;
    set_real_ip_from  162.158.0.0/15;
    set_real_ip_from  172.64.0.0/13;
    set_real_ip_from  173.245.48.0/20;
    set_real_ip_from  188.114.96.0/20;
    set_real_ip_from  190.93.240.0/20;
    set_real_ip_from  197.234.240.0/22;
    set_real_ip_from  198.41.128.0/17;

    # Security headers
    add_header X-Frame-Options        "SAMEORIGIN"   always;
    add_header X-Content-Type-Options "nosniff"      always;
    add_header X-XSS-Protection       "1; mode=block" always;
    add_header Referrer-Policy        "no-referrer"  always;

    location /ws/ {
        proxy_pass http://iptv_backend;
        proxy_http_version 1.1;
        proxy_set_header Upgrade    $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host       $host;
        proxy_set_header X-Real-IP  $remote_addr;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }

    location /api/ {
        limit_req zone=api burst=50 nodelay;
        proxy_pass http://iptv_backend;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host            $host;
        proxy_set_header X-Real-IP       $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        client_max_body_size 200M;
        proxy_read_timeout 120s;
    }

    # Xtream Codes API on port 443 (HTTPS)
    location ~ ^/(player_api\.php|get\.php|xmltv\.php|panel_api\.php) {
        limit_req zone=api burst=30 nodelay;
        proxy_pass http://iptv_backend;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host      $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_buffering off;
        proxy_read_timeout 30s;
        add_header Access-Control-Allow-Origin * always;
    }

    location /hls/ {
        alias /var/iptv/hls/;
        types { application/vnd.apple.mpegurl m3u8; video/mp2t ts; }
        location ~* \.m3u8$ { add_header Cache-Control "no-cache" always; add_header Access-Control-Allow-Origin * always; }
        location ~* \.ts$    { add_header Cache-Control "public, max-age=10" always; add_header Access-Control-Allow-Origin * always; }
        limit_conn stream_conn 10;
    }

    location /live/ {
        limit_req  zone=stream burst=20 nodelay;
        limit_conn stream_conn 5;
        proxy_pass http://iptv_backend;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host      $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_buffering off;
        proxy_read_timeout 120s;
        add_header Access-Control-Allow-Origin * always;
    }

    location / {
        root /var/www/iptv-panel;
        index index.html;
        try_files $uri $uri/ /index.html;
        location ~* \.(js|css|svg|woff|woff2|ico)$ {
            expires 30d;
            add_header Cache-Control "public, immutable";
        }
    }

    gzip on;
    gzip_vary on;
    gzip_min_length 1024;
    gzip_types text/plain application/json application/javascript text/css;
}

# ── Port 8080 — Xtream Codes API (direct, no Cloudflare) ─────
server {
    listen 8080;
    listen [::]:8080;
    server_name tv.keitanyfrank.store _;

    access_log /var/log/nginx/iptv-xtream.log combined buffer=16k flush=5s;
    error_log  /var/log/nginx/iptv-xtream-error.log warn;

    add_header Access-Control-Allow-Origin  * always;
    add_header Access-Control-Allow-Methods "GET, POST, OPTIONS" always;
    add_header Access-Control-Allow-Headers "Range, Authorization" always;

    # HLS segments — served directly by Nginx
    location /hls/ {
        alias /var/iptv/hls/;
        types {
            application/vnd.apple.mpegurl m3u8;
            video/mp2t                    ts;
        }
        location ~* \.m3u8$ {
            add_header Cache-Control "no-cache, no-store, must-revalidate" always;
            add_header Access-Control-Allow-Origin * always;
        }
        location ~* \.ts$ {
            add_header Cache-Control "public, max-age=10" always;
            add_header Access-Control-Allow-Origin * always;
        }
        limit_conn stream_conn 10;
    }

    # Xtream Codes API endpoints
    location ~ ^/(player_api\.php|get\.php|xmltv\.php|panel_api\.php) {
        limit_req zone=api burst=30 nodelay;
        proxy_pass http://iptv_backend;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host      $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_connect_timeout 10s;
        proxy_send_timeout    30s;
        proxy_read_timeout    30s;
        proxy_buffering off;
    }

    # Live stream delivery
    location /live/ {
        limit_req  zone=stream burst=20 nodelay;
        limit_conn stream_conn 5;
        proxy_pass http://iptv_backend;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host      $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_connect_timeout 15s;
        proxy_send_timeout    120s;
        proxy_read_timeout    120s;
        proxy_buffering off;
    }

    location / { return 444; }
}
