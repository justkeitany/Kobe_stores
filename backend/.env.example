# Database
DATABASE_URL=postgresql+asyncpg://iptv:yourpassword@localhost:5432/iptvpanel

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-this-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123

# Server
SERVER_URL=https://tv.keitanyfrank.store
PANEL_PORT=8000

# Bunny CDN (or any pull-zone CDN) for viewer-facing HLS delivery + logos.
# Set to your CDN host to deliver .m3u8/.ts/logos from the nearest edge; API,
# auth and admin always stay on SERVER_URL. Leave blank to deliver from the
# origin (clear it if the CDN is ever down — the panel keeps working).
BUNNY_CDN_URL=https://cdn.keitanyfrank.store

# HLS / FFmpeg
HLS_SEGMENT_TIME=2
HLS_LIST_SIZE=6
HLS_OUTPUT_DIR=/var/iptv/hls
FFMPEG_PATH=/usr/bin/ffmpeg

# Stream
MAX_RETRY_ATTEMPTS=5
HEALTH_CHECK_INTERVAL=30

# Allowed admin IPs (comma separated, leave empty to allow all)
ADMIN_IP_WHITELIST=

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# AI assistant (Claude) — leave ANTHROPIC_API_KEY empty to keep AI features off.
ANTHROPIC_API_KEY=
AI_MODEL=claude-opus-4-8
# suggest | autofix  (autofix applies only reversible whitelisted actions)
AI_AUTONOMY=suggest
AI_DAILY_CALL_CAP=200

# Cloudflare R2 (S3-compatible) — premium-playlist backup/export. Leave blank to
# keep export dormant. Create an R2 API token with Object Read & Write scoped to
# the bucket. The endpoint is derived from R2_ACCOUNT_ID; region is always "auto".
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Key prefix inside the bucket (default playlists/).
R2_PREFIX=playlists/
# Optional public base (R2 custom domain) for friendly return URLs only;
# uploads and presigned downloads work without it.
R2_PUBLIC_BASE=
